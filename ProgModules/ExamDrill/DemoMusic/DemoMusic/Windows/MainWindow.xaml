<Window x:Class="DemoMusic.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DemoMusic"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="Товары" Height="450" Width="800">

    <Window.Resources>
        <Style x:Key="ListBoxItemStretch" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Верхняя панель -->
        <DockPanel DockPanel.Dock="Top"
                   Margin="5">
            <Button Content="Выход"
                    DockPanel.Dock="Left"
                    Click="ButtonExit_Click"
                    Width="60"/>
            <TextBlock DockPanel.Dock="Right"
                       VerticalAlignment="Center">
                <Run Text="Добро пожаловать,"/>
                <Run Name="WelcomeName"/><Run Text="!"/>
            </TextBlock>
            <StackPanel/>
        </DockPanel>
        <!-- Панель фильтра и поиска -->
        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    Margin="5"
                    Name="PanelFind"
                    Visibility="Collapsed">
            <Label Content="Поиск"/>
            <TextBox Name="SearchBox"
                     Width="100"
                     VerticalAlignment="Center"
                     TextChanged="SearchBox_TextChanged"/>
            <RadioButton Name="RadioUp"
                         Content="по возрастанию"
                         Margin="5 0 0 0"
                         IsChecked="True"
                         VerticalAlignment="Center"
                         Checked="RadioUp_Checked"/>
            <RadioButton Name="RadioDown"
                         Content="по убыванию"
                         Margin="5 0 0 0"
                         VerticalAlignment="Center"
                         Checked="RadioDown_Checked"/>
            <ComboBox Name="ComboSuppliers"
                      Width="120"
                      Margin="5 0 0 0"
                      VerticalAlignment="Center"
                      SelectedIndex="0"
                      SelectionChanged="Combo_SelectionChanged"/>

        </StackPanel>
        <!-- Нижняя панель -->
        <DockPanel DockPanel.Dock="Bottom"
                    Margin="5">
            <StackPanel Name="CRUD"
                        Orientation="Horizontal"
                        Visibility="Collapsed"
                        DockPanel.Dock="Left">
                <Button Content="Добавить товар"
                        Click="ButtonAdd_Click"
                        Margin="0 0 5 0"
                        Width="140"/>
                <Button Content="Удалить товар"
                        Click="ButtonDelete_Click"
                        Margin="0 0 5 0"
                        Width="140"/>
            </StackPanel>
            <Label Name="UserRole"
                   DockPanel.Dock="Right"/>
            <Button Content="Список заказов"
                    Click="ButtonOrders_Click"
                    Name="ButtonOrders"
                    DockPanel.Dock="Left"
                    Visibility="Collapsed"
                    Width="140"/>
            <StackPanel/>
        </DockPanel>
        <!-- Список товаров -->
        <ListBox Name="ListProducts"
                 Margin="5 0 5 0"
                 ItemContainerStyle="{StaticResource ListBoxItemStretch}"/>
    </DockPanel>
</Window>
